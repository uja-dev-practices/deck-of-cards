# de producción y el esqueleto de variables. Nunca subimos .env.local.
.env.local
.env.*.local

# Override de Docker Compose para desarrollo local (no debe llegar a producción)
docker-compose.override.yml

# Configuraciones del editor
.vscode/
.idea/
